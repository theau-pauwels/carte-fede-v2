---
import Layout from "@layouts/Layout.astro"
---
<Layout title="Réinitialiser le mot de passe">
  <main class="flex-1 flex flex-col gap-4 items-center p-4 justify-center">
    <section class="w-full max-w-md rounded-xl bg-white px-5 py-6 shadow-lg sm:px-8">
      <h1 class="mb-2 bg-white text-xl font-semibold text-bleu sm:text-2xl">Réinitialiser le mot de passe</h1>
      <form id="reset-form" class="stack" novalidate>
        <div class="password-field">
          <input
            id="new_password"
            name="new_password"
            type="password"
            placeholder="Nouveau mot de passe (min 8)"
            minlength="8"
            class="password-input border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
            required
          />
          <button
            type="button"
            class="password-toggle"
            data-password-toggle
            aria-label="Afficher le mot de passe"
            aria-pressed="false"
          >
            <svg class="icon-show" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                d="M1.5 12s3.5-6 10.5-6 10.5 6 10.5 6-3.5 6-10.5 6S1.5 12 1.5 12Z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
              <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="1.8"></circle>
            </svg>
            <svg class="icon-hide" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                d="M3 3l18 18"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
              ></path>
              <path
                d="M10.6 6.3A11.3 11.3 0 0 1 12 6c7 0 10.5 6 10.5 6a18.5 18.5 0 0 1-3.2 3.8M6.7 6.7C3.5 8.7 1.5 12 1.5 12s3.5 6 10.5 6c1.8 0 3.4-.4 4.8-1"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </button>
        </div>
        <div class="password-field">
          <input
            id="confirm_password"
            name="confirm_password"
            type="password"
            placeholder="Confirmer le mot de passe"
            minlength="8"
            class="password-input border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
            required
          />
          <button
            type="button"
            class="password-toggle"
            data-password-toggle
            aria-label="Afficher le mot de passe"
            aria-pressed="false"
          >
            <svg class="icon-show" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                d="M1.5 12s3.5-6 10.5-6 10.5 6 10.5 6-3.5 6-10.5 6S1.5 12 1.5 12Z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
              <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="1.8"></circle>
            </svg>
            <svg class="icon-hide" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                d="M3 3l18 18"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
              ></path>
              <path
                d="M10.6 6.3A11.3 11.3 0 0 1 12 6c7 0 10.5 6 10.5 6a18.5 18.5 0 0 1-3.2 3.8M6.7 6.7C3.5 8.7 1.5 12 1.5 12s3.5 6 10.5 6c1.8 0 3.4-.4 4.8-1"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </button>
        </div>

        <button
          type="submit"
          class="rounded-lg border-2 border-blue-900 bg-blue-900 px-4 py-2 text-white transition duration-150 hover:bg-blue-50 hover:text-blue-50"
        >
          Mettre à jour
        </button>

        <p id="msg" aria-live="polite"></p>
      </form>
      <style>
        .stack { display:flex; flex-direction:column; gap:.8rem; max-width:380px; }
        input, button { padding:.55rem .7rem; font-size:1rem; }
      </style>
    </section>
  </main>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const token = params.get("token") || "";
  const msg = document.getElementById("msg") as HTMLParagraphElement | null;
  const resetForm = document.getElementById("reset-form") as HTMLFormElement | null;

  if (!token && msg) {
    msg.textContent = "Lien invalide.";
    msg.className = "text-red-700";
  }

  resetForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!msg) return;

    msg.textContent = "";
    const data = Object.fromEntries(new FormData(e.currentTarget as HTMLFormElement).entries());
    if (data.new_password !== data.confirm_password) {
      msg.textContent = "Les mots de passe ne correspondent pas.";
      msg.className = "text-red-700";
      return;
    }
    const res = await fetch("/api/auth/reset-password", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ token, new_password: data.new_password }),
    });
    if (res.ok) {
      msg.textContent = "Mot de passe mis a jour. Tu peux te connecter.";
      msg.className = "text-green-700";
    } else {
      try {
        const j = await res.json();
        msg.textContent = j.error || "Erreur";
      } catch {
        msg.textContent = "Erreur";
      }
      msg.className = "text-red-700";
    }
  });
</script>
