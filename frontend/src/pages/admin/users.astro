---
import Layout from "../../layouts/Layout.astro";
import AdminUsersTable from "../../components/AdminUsersTable";
import RequireAuth from "@components/RequireAuth";
---
<Layout title="Gestion des utilisateurs">
  <main class="flex-1 flex flex-col gap-4 items-stretch p-4 sm:items-center sm:justify-center">
    <RequireAuth client:load>
    <div class="w-full max-w-6xl">
      <h1 class="mb-1 bg-white text-2xl font-semibold text-blue-800">Gestion des utilisateurs</h1>
      <AdminUsersTable client:load />
    </div>
    </RequireAuth>
  </main>
</Layout>
