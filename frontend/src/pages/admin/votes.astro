---
import Layout from "../../layouts/Layout.astro";
import RequireAuth from "@components/RequireAuth";
import AdminVotesManager from "../../components/AdminVotesManager";
---

<Layout title="Admin votes">
  <main class="min-h-[calc(100vh-12rem)] bg-gradient-to-b from-slate-50 via-white to-blue-50/40 px-4 py-8 sm:px-6 lg:px-8">
    <RequireAuth client:load>
      <section class="mx-auto w-full max-w-6xl space-y-4">
        <h1 class="text-3xl font-semibold text-blue-900">Administration des votes</h1>
        <p class="text-sm text-slate-600">
          Crée des rooms de vote, gère leur durée et ouvre/ferme une session de vote active par room.
        </p>
        <AdminVotesManager client:load />
      </section>
    </RequireAuth>
  </main>
</Layout>
